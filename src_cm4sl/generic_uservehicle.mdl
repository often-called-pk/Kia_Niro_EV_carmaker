  </Block>
  <Block BlockType="EnablePort" Name="Enable" SID="2647">
    <PortCounts/>
    <P Name="Position">[55, 15, 75, 35]</P>
    <P Name="ZOrder">-8</P>
  </Block>
  <Block BlockType="SubSystem" Name="Brake" SID="2648">
    <PortCounts in="3" out="2"/>
