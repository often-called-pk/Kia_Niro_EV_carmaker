<chart id="383">
  <P Name="name">CarMaker/MATLAB Function30</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">383</P>
  <P Name="ssIdHighWaterMark">22</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">38</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">slip_estimator</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">383</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [slip_fl, slip_fr, slip_rl, slip_rr] = ...
    slip_estimator(vx, omega_fl, omega_fr, omega_rl, omega_rr, ...
                        re_fl, re_fr, re_rl, re_rr, eps_vx)

if abs(vx) &lt; eps_vx
    slip_fl = 0;
    slip_fr = 0;
    slip_rl = 0;
    slip_rr = 0;
else
    slip_fl = (vx - omega_fl * re_fl) / max(abs(vx), eps_vx);
    slip_fr = (vx - omega_fr * re_fr) / max(abs(vx), eps_vx);
    slip_rl = (vx - omega_rl * re_rl) / max(abs(vx), eps_vx);
    slip_rr = (vx - omega_rr * re_rr) / max(abs(vx), eps_vx);

    slip_fl = min(max(slip_fl, 0), 1);
    slip_fr = min(max(slip_fr, 0), 1);
    slip_rl = min(max(slip_rl, 0), 1);
    slip_rr = min(max(slip_rr, 0), 1);
end</P>
      </eml>
    </state>
    <data SSID="4" name="vx">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
