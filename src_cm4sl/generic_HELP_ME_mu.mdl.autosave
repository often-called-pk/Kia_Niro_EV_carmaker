<chart id="292">
  <P Name="name">CarMaker/MATLAB Function26</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">292</P>
  <P Name="ssIdHighWaterMark">48</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">34</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">summary</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">292</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [slip_front_avg, slip_rear_avg, slip_vehicle_avg, ...
          fx_front_total, fx_rear_total, ...
          fy_front_total, fy_rear_total, ...
          mu_long_front_avg, mu_long_rear_avg, mu_long_vehicle_avg, ...
          mu_lat_front_avg, mu_lat_rear_avg, mu_lat_vehicle_avg, ...
          mu_comb_front_avg, mu_comb_rear_avg, mu_comb_vehicle_avg] = ...
          summary( ...
          slip_fl, slip_fr, slip_rl, slip_rr, ...
          fx_fl, fx_fr, fx_rl, fx_rr, ...
          fy_fl, fy_fr, fy_rl, fy_rr, ...
          mu_long_fl, mu_long_fr, mu_long_rl, mu_long_rr, ...
          mu_lat_fl, mu_lat_fr, mu_lat_rl, mu_lat_rr, ...
          mu_comb_fl, mu_comb_fr, mu_comb_rl, mu_comb_rr)

slip_front_avg   = (slip_fl + slip_fr) / 2;
slip_rear_avg    = (slip_rl + slip_rr) / 2;
slip_vehicle_avg = (slip_fl + slip_fr + slip_rl + slip_rr) / 4;

fx_front_total = fx_fl + fx_fr;
fx_rear_total  = fx_rl + fx_rr;

fy_front_total = fy_fl + fy_fr;
fy_rear_total  = fy_rl + fy_rr;

mu_long_front_avg   = (mu_long_fl + mu_long_fr) / 2;
mu_long_rear_avg    = (mu_long_rl + mu_long_rr) / 2;
mu_long_vehicle_avg = (mu_long_fl + mu_long_fr + mu_long_rl + mu_long_rr) / 4;

mu_lat_front_avg   = (mu_lat_fl + mu_lat_fr) / 2;
mu_lat_rear_avg    = (mu_lat_rl + mu_lat_rr) / 2;
mu_lat_vehicle_avg = (mu_lat_fl + mu_lat_fr + mu_lat_rl + mu_lat_rr) / 4;

mu_comb_front_avg   = (mu_comb_fl + mu_comb_fr) / 2;
mu_comb_rear_avg    = (mu_comb_rl + mu_comb_rr) / 2;
mu_comb_vehicle_avg = (mu_comb_fl + mu_comb_fr + mu_comb_rl + mu_comb_rr) / 4;</P>
      </eml>
    </state>
