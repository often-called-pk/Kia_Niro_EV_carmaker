__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_50.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="50">
  <P Name="name">CarMaker/EKF</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">50</P>
  <P Name="ssIdHighWaterMark">20</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="updateMethod">DISCRETE</P>
  <P Name="sampleTime">-1</P>
  <P Name="chartFileNumber">1</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">soc_ekf_paper_1rc</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">50</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [soc_hat, u1_hat, ul_hat, innov, K_out, P_out] = ...
    soc_ekf_paper_1rc(I, UL_meas, Uoc, R0_est, R0nom, R1, C1, dUoc_dSoc, reset, Qcap_est,Qnom)

    persistent x_hat P initialized

    Dt   = 0.01;
    Qnom = 3.6*Qnom;
    Qcap_est = Qcap_est*3600;
    

    Rekf = 1e-1;

    if isempty(initialized) || reset
        x_hat = [0.8;
                 0.0];

        P = [1e-6, 0;
             0,    1e-6];

        initialized = true;
    end

    
    if Qcap_est &gt; 0
        Q0 = Qcap_est;
    else
        Q0 = Qnom;
    end

    
    if R0_est &gt; 1e-3
        R0 = R0_est;
    else
        R0 = R0nom;
    end

    tau1 = R1 * C1;
    a1 = exp(-Dt / tau1);

    A = [1,  0;
         0, a1];

    B = [-Dt / Q0;
         R1 * (1 - exp(-Dt / tau1))];

    sigma_I2 = 1e-1;
    Q_input  = (B * B.&apos;) * sigma_I2;

    Q_base = [1e-8, 0;
              0,    1e-8];

    Qekf = Q_base + Q_input;

    % (1) State prediction
    x_pred = A * x_hat + B * I;

    % (2) Covariance prediction
    P_pred = A * P * A.&apos; + Qekf;

    % (3) Measurement Jacobian
    C = [dUoc_dSoc, -1];

    % (4) Predicted output
    ul_hat = Uoc - R0 * I - x_pred(2);

    % (5) Kalman gain
    S = C * P_pred * C.&apos; + Rekf;
    K = (P_pred * C.&apos;) / S;

    % (6) State update
    innov = UL_meas - ul_hat;
    x_hat = x_pred + K * innov;

    % (7) Covariance update
    I2 = eye(2);
    P = (I2 - K * C) * P_pred;

    % Outputs
    soc_hat = x_hat(1);
    u1_hat  = x_hat(2);
    K_out   = K;
    P_out   = P;
end</P>
      </eml>
    </state>
    <data SSID="4" name="I">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="soc_hat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="UL_meas">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="Uoc">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="R0_est">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="18" name="R0nom">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
