<?xml version="1.0" encoding="utf-8"?>
<chart id="347">
  <P Name="name">CarMaker/MATLAB Function28</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">347</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">21</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">36</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">vertical_load_combined</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">347</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [fz_fl, fz_fr, fz_rl, fz_rr, fz_front_total, fz_rear_total] = ...
    vertical_load_combined(mhat, ax_eff, ay, lf, lr, h_cg, tw_f, tw_r)

g = 9.81;
kf = 0.55;
kr = 0.45;
fz_min = 300;

L = lf + lr;

% Transfert longitudinal
fz_front_total = (mhat * g * lr - mhat * ax_eff * h_cg) / L;
fz_rear_total  = (mhat * g * lf + mhat * ax_eff * h_cg) / L;

% Transfert lateral
dfz_f_lat = (mhat * ay * h_cg / tw_f) * kf;
dfz_r_lat = (mhat * ay * h_cg / tw_r) * kr;

% Charges roue par roue
fz_fl = fz_front_total/2 + dfz_f_lat/2;
fz_fr = fz_front_total/2 - dfz_f_lat/2;

fz_rl = fz_rear_total/2 + dfz_r_lat/2;
fz_rr = fz_rear_total/2 - dfz_r_lat/2;

% Saturation mini
fz_fl = max(fz_fl, fz_min);
fz_fr = max(fz_fr, fz_min);
fz_rl = max(fz_rl, fz_min);
fz_rr = max(fz_rr, fz_min);

% Totaux recalcules
fz_front_total = fz_fl + fz_fr;
fz_rear_total  = fz_rl + fz_rr;</P>
      </eml>
    </state>
    <data SSID="4" name="mhat">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="fz_fl">
