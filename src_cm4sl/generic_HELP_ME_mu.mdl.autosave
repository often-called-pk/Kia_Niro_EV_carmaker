      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">275</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [mu_comb_fl, mu_comb_fr, mu_comb_rl, mu_comb_rr] = ...
    mu_combined_estimator(mu_long_fl, mu_long_fr, mu_long_rl, mu_long_rr, ...
                               mu_lat_fl, mu_lat_fr, mu_lat_rl, mu_lat_rr)

mu_max = 1.5;

mu_comb_fl = sqrt(mu_long_fl^2 + mu_lat_fl^2);
mu_comb_fr = sqrt(mu_long_fr^2 + mu_lat_fr^2);
mu_comb_rl = sqrt(mu_long_rl^2 + mu_lat_rl^2);
mu_comb_rr = sqrt(mu_long_rr^2 + mu_lat_rr^2);

mu_comb_fl = min(mu_comb_fl, mu_max);
mu_comb_fr = min(mu_comb_fr, mu_max);
mu_comb_rl = min(mu_comb_rl, mu_max);
mu_comb_rr = min(mu_comb_rr, mu_max);</P>
      </eml>
    </state>
