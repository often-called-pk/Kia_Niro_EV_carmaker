  <eml>
    <P Name="name">fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">175</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function SoC = fcn(Ct,SOC_init,I)

% Ct : Battery total capacity (mAh)
% SOC_init : Initial SoC (%)
% I : Cumulative Current (used capacity in mAh)
% y : SoC

 SoC = SOC_init - 100*(I/Ct) ;

end</P>
        <P Name="vectorOutputs1D">1</P>
      </eml>
    </state>
    <data SSID="4" name="Ct">
      <P Name="scope">INPUT_DATA</P>
