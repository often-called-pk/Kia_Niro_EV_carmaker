<?xml version="1.0" encoding="utf-8"?>
<chart id="256">
  <P Name="name">CarMaker/MATLAB Function23</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">256</P>
  <P Name="ssIdHighWaterMark">30</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">31</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">longitudinal_force_estimator</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">256</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [fx_fl, fx_fr, fx_rl, fx_rr] = ...
    longitudinal_force_estimator(slip_fl, slip_fr, slip_rl, slip_rr, ...
                                      fz_fl, fz_fr, fz_rl, fz_rr, ...
                                      brake_cmd, throttle_cmd)

k_lambda = 5.0;   % gain a ajuster
mu_x_max = 1.2;

brake_th = 0.05;
throttle_th = 0.05;

mu_x_fl = min(max(k_lambda * slip_fl, 0), mu_x_max);
mu_x_fr = min(max(k_lambda * slip_fr, 0), mu_x_max);
mu_x_rl = min(max(k_lambda * slip_rl, 0), mu_x_max);
mu_x_rr = min(max(k_lambda * slip_rr, 0), mu_x_max);

if brake_cmd &gt; brake_th
    sgn = -1;
elseif throttle_cmd &gt; throttle_th
    sgn = 1;
else
    sgn = 0;
end

fx_fl = sgn * mu_x_fl * fz_fl;
fx_fr = sgn * mu_x_fr * fz_fr;
fx_rl = sgn * mu_x_rl * fz_rl;
fx_rr = sgn * mu_x_rr * fz_rr;</P>
      </eml>
    </state>
    <data SSID="4" name="slip_fl">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
