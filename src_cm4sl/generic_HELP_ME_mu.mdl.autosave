    mu_long_estimator(fx_fl, fx_fr, fx_rl, fx_rr, fz_fl, fz_fr, fz_rl, fz_rr)

mu_min = 0.0;
mu_max = 1.5;
fz_eps = 1.0;

if fz_fl &lt;= fz_eps
