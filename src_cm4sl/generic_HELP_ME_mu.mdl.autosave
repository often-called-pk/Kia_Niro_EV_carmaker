        <P Name="isEML">1</P>
        <P Name="script">function y = compute_y(ax,beta) 
g=9.81; 
f=0.015; 
delta=1; 
y = delta*ax + g*f + g*sin(beta);</P>
      </eml>
    </state>
    <data SSID="4" name="ax">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
