__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_55.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="55">
  <P Name="name">CarMaker/IPG Vehicle/PowerTrain/User RearDriven PowerTrain/Subsystem1/EKF1</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">55</P>
  <P Name="ssIdHighWaterMark">18</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="updateMethod">DISCRETE</P>
  <P Name="sampleTime">-1</P>
  <P Name="chartFileNumber">8</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">soc_ekf_paper_1rc</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">55</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [soc_hat, u1_hat, ul_hat, innov, K_out, P_out] = soc_ekf_paper_1rc(I, UL_meas, Uoc, R0, R1, C1, dUoc_dSoc, reset,dR0)

    persistent x_hat P initialized


    Dt  = 0.01;         
    Q0  = 3600 * 4.8;   
    
    Qekf = [1e-8, 0;
            0,    1e-8];

    Rekf = 1e-2;


    if isempty(initialized) || reset
        x_hat = [0.8;
                 0.0];

        P = [1e-6, 0;
             0,    1e-6];

        initialized = true;
    end

    SOC_k = x_hat(1);
    U1_k  = x_hat(2);
    SOC_k = min(max(SOC_k, 0.0), 1.0);


    tau1 = R1 * C1;
    a1 = exp(-Dt / tau1);

    A = [1,  0;
         0, a1];

    B = [-Dt / Q0;
         R1 * (1 - exp(-(Dt/tau1)))];

    % =========================================================
    % (1) STATE PREDICTION
    % X(k|k-1) = A X(k-1|k-1) + B U(k-1)
    % =========================================================
    x_pred = A * x_hat + B * I;

    

    
    % (2) COVARIANCE PREDICTION
    % P(k|k-1) = A P(k-1) A&apos; + Q
    
    P_pred = A * P * A.&apos; + Qekf;

    
    % (3) MEASUREMENT JACOBIAN
    % C(k) = dg/dx = [dUoc/dSOC, 1]
    
    C = [dUoc_dSoc-dR0*I, -1];

    
    % PREDICTED OUTPUT
    % UL(k) = Uoc(SOC(k)) + I(k)R0 + U1(k)
    
    ul_hat = Uoc - R0 * I - x_pred(2);

    
    % (4) KALMAN GAIN
    % K = P C&apos; (C P C&apos; + R)^(-1)
   
    S = C * P_pred * C.&apos; + Rekf;
  

    K = (P_pred * C.&apos;) / S;

    
    % (5) STATE UPDATE
    % X(k|k) = X(k|k-1) + K [ Z(k) - g(X(k),U(k)) ]
    
    innov = UL_meas - ul_hat;

    x_hat = x_pred + K * innov;
    

    
    % (6) COVARIANCE UPDATE
    % P(k|k) = [I - K C] P(k|k-1)
  
    I2 = eye(2);
    %P = (I2 - K*C) * P_pred * (I2 - K*C).&apos; + K*Rekf*K.&apos;;
    P = (I2 - K*C) * P_pred ;

    % Outputs
    soc_hat = x_hat(1);
    u1_hat  = x_hat(2);
    K_out   = K;
    P_out   = P;
end</P>
      </eml>
    </state>
    <data SSID="4" name="I">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="soc_hat">
