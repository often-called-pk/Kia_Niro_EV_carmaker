__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_20.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="20">
  <P Name="name">CarMaker/IPG Vehicle/PowerTrain/User RearDriven PowerTrain/Motor Model/Cross Coupling Removal/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">20</P>
  <P Name="ssIdHighWaterMark">17</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">3</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">20</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [target_Vd,target_Vq] = fcn(Id,Iq,control_Vd,control_Vq,rotor_electrical_speed, Ldq, Rs, M, PP, Vdc)
% We are using complex variables to simplify the vectorial operation -
% particlarly the time derivative
Idq = Id + i*Iq;
lambda = Ldq*Idq + M;
control_Vdq = control_Vd + i*control_Vq;
% For a vector lambda rotating with speed rotor_electrical_speed, the time
% derivative is i*rotor_electrical_speed*lambda
target_Vdq = control_Vdq + i*rotor_electrical_speed*lambda;
target_Vd = real(target_Vdq);
target_Vq = imag(target_Vdq);
end
</P>
      </eml>
    </state>
    <data SSID="16" name="target_Vd">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="17" name="target_Vq">
