<ConfigSet>
  <Object ObjectID="1" ClassName="Simulink.ConfigSet">
    <P Name="ExtraOptions" Class="char"/>
    <P Name="Name" Class="char">Configuration</P>
    <P Name="CurrentDlgPage" Class="char">Solver</P>
    <P Name="ConfigPrmDlgPosition" Class="double">[517.0, 260.0, 1403.0, 918.0]</P>
    <P Name="Description" Class="char"/>
    <P Name="Version" Class="char">25.0.0</P>
    <Array PropName="Components" Type="Simulink.ConfigComponent" Dimension="9*1">
      <Object ObjectID="2" ClassName="Simulink.SolverCC">
        <P Name="StartTime" Class="char">0.0</P>
        <P Name="StopTime" Class="char">inf</P>
        <P Name="AbsTol" Class="char">auto</P>
        <P Name="AutoScaleAbsTol" Class="char">on</P>
        <P Name="FixedStep" Class="char">auto</P>
        <P Name="InitialStep" Class="char">auto</P>
        <P Name="MaxOrder" Class="double">5.0</P>
        <P Name="ZcThreshold" Class="char">auto</P>
        <P Name="ConsecutiveZCsStepRelTol" Class="char">10*128*eps</P>
        <P Name="MaxConsecutiveZCs" Class="char">1000</P>
        <P Name="ExtrapolationOrder" Class="double">4.0</P>
        <P Name="NumberNewtonIterations" Class="double">1.0</P>
        <P Name="MaxStep" Class="char">auto</P>
        <P Name="MinStep" Class="char">auto</P>
        <P Name="MaxConsecutiveMinStep" Class="char">1</P>
        <P Name="RelTol" Class="char">1e-3</P>
        <P Name="EnableMultiTasking" Class="char">on</P>
        <P Name="AllowMultiTaskInputOutput" Class="char">off</P>
        <P Name="ConcurrentTasks" Class="char">off</P>
