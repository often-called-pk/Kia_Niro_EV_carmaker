      <Display>image(imread(&apos;CarMakerSys.png&apos;));</Display>
    </Mask>
    <System Ref="system_1726"/>
  </Block>
  <Block BlockType="Reference" Name="Edit Model&#xA;Configuration" SID="1727">
    <PortCounts/>
    <P Name="Position">[40, 130, 103, 193]</P>
    <P Name="ZOrder">-2</P>
    <P Name="BackgroundColor">lightBlue</P>
