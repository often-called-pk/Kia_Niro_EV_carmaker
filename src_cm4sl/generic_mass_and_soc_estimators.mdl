    <P Name="SourceProductName">CarMaker4SL</P>
    <InstanceData>
      <P Name="SFunctionModules">&apos;&apos;</P>
      <P Name="SFcnIsStateOwnerBlock">off</P>
      <P Name="MultithreadedSim">auto</P>
    </InstanceData>
  </Block>
  <Block BlockType="SubSystem" Name="Open CarMaker GUI" SID="1728">
