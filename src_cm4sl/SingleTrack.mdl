    <P Name="ZOrder">-12</P>
  </Block>
  <Block BlockType="SubSystem" Name="VehicleSource_ModelMgr" SID="3239">
    <PortCounts in="1" out="1"/>
    <P Name="Position">[245, 70, 275, 100]</P>
    <P Name="ZOrder">-13</P>
    <Mask SelfModifiable="on">
      <Type>Compare To Constant</Type>
      <Display IconUnits="normalized">disp(str)</Display>
      <Description>Simulink:masks:CompareToConstant_MD</Description>
      <Initialization>blkName = gcb;

if strcmp(get_param(gcbh,&apos;OutDataTypeStr&apos;),&apos;boolean&apos;)
	setValue = &apos;boolean&apos;;
else
	setValue = &apos;fixdt(0, 8)&apos;;
end

set_param([blkName,&apos;/Compare&apos;],&apos;relop&apos;,relop, ...
	&apos;OutDataTypeStr&apos;, setValue, &apos;ZeroCross&apos;, ZeroCross);

str = [relop,&apos; C&apos;]; %default

const_str = get_param(blkName, &apos;const&apos;);

if isempty(strfind(const_str, &apos; &apos;)) &amp;&amp; isempty(strfind(const_str, &apos;,&apos;))
    % scalar or single expression
    if isempty(str2num(const_str))
        %expression
        str = [relop, &apos; &apos;, const_str];
    elseif length(const) == 1
        str = [relop,&apos; &apos;,num2str(double(const))];
    end
end</Initialization>
      <Capabilities>slmaskedcaps(gcbh)</Capabilities>
      <MaskParameter Name="relop" Type="popup" Evaluate="off" Tunable="off">
        <Prompt>Simulink:masks:Operator_MP</Prompt>
        <Value>~=</Value>
        <TypeOptions>
          <Option>==</Option>
          <Option>~=</Option>
          <Option>&lt;</Option>
          <Option>&lt;=</Option>
          <Option>&gt;=</Option>
          <Option>&gt;</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="const" Type="edit">
        <Prompt>Simulink:masks:ConstantValue_MP</Prompt>
        <Value>2</Value>
      </MaskParameter>
      <MaskParameter Name="OutDataTypeStr" Type="popup" Evaluate="off" Tunable="off">
        <Prompt>Simulink:masks:OutputDataType_MP</Prompt>
        <Value>boolean</Value>
        <Alias>LogicOutDataTypeMode</Alias>
        <TypeOptions>
          <Option>Simulink:masks:uint8</Option>
          <Option>Simulink:masks:boolean</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="ZeroCross" Type="checkbox" Evaluate="off" Tunable="off">
        <Prompt>Simulink:masks:EnableZerocrossingDetection_MP</Prompt>
        <Value>off</Value>
        <Callback>sl(&apos;zeroCrossEnable&apos;, gcbh);</Callback>
      </MaskParameter>
    </Mask>
    <System Ref="system_3239"/>
  </Block>
