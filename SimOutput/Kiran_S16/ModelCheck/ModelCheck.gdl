class "ModelCheck"

frame DEFAULT {
	edgecolor black
	interiorcolor white
	style "--"
	thickness 0.01
	noshadow
	font "Helvetica"
	fontsize 0.4
	textcolor black
	autoclear
}

line DEFAULT {
	color		black
	thickness	0.2
	style		solid
}

grid DEFAULT {
	kind		lined
	color		blue
	style		".."
	thickness	0.01
}

axis DEFAULT {
	scaling		linear
	color		black
	style		"--"
	thickness	0.01
	majorticklength 0.15
	minorticklength 0.06
	labelformat	automatic
	font		"Helvetica"
	fontsize	0.3
	textcolor	black
	tickdirection	same
	snapmajorticks
	gridevery	same
	notarrowed
	notconnected
	majortickevery	5
	noreverseaxis
	notemphasized
}

plot2d DEFAULT {
	color		automatic
	edgecolor	automatic
	interiorcolor	automatic
	style		automatic
	symbol		automatic
	kind		lined
	thickness	0.01
}

plot3d DEFAULT {
	color		automatic
	edgecolor	automatic
	interiorcolor	automatic
	style		automatic
	thickness	.01
	symbol		automatic
	kind		lined
}

grid gitter {
	color		black
	thickness	0.01
}

PaperSize         DinA4
PaperOrientation  landscape


file lForce {
	"" ascii commentlineintro "#" array of record {
	    l :    float   # mm
	    F :    float   # N
	}
}


file vForce {
	"" ascii commentlineintro "#" array of record {
	    v :   float   # m/s
	    F :   float   # N
	}
}

